{
  "name": "@rivuty/oxfmt-config",
  "version": "1.0.0",
  "description": "Shared oxfmt configuration for TypeScript projects",
  "keywords": [
    "formatting",
    "oxc",
    "oxfmt",
    "oxfmt-config",
    "typescript"
  ],
  "license": "MIT",
  "author": "Oleg Michailov",
  "repository": {
    "type": "git",
    "url": "https://github.com/rivuty/oxfmt-config.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "typecheck": "tsc",
    "verify": "run-p -c lint format typecheck",
    "prepublishOnly": "run-p -c verify build",
    "release": "release-it"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@rivuty/oxlint-config": "^1.2.0",
    "@types/node": "^25.5.2",
    "lefthook": "^2.1.5",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "release-it": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "oxfmt": ">=0.43.0"
  },
  "packageManager": "pnpm@10.32.1"
}
